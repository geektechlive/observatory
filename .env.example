# Set these as encrypted environment variables in Cloudflare Pages
# Never commit the real values
NASA_API_KEY=

# NASA FIRMS active-fire MAP_KEY — free at
# https://firms.modaps.eosdis.nasa.gov/api/map_key (5000 req / 10 min)
# Powers /api/fires; the fire layer is empty until this is set.
FIRMS_MAP_KEY=

# OpenAQ v3 API key — free at https://explore.openaq.org/register (60 req/min)
# Powers /api/air-quality (PM2.5 map layer); empty until set.
OPENAQ_API_KEY=
